NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://greatandhra:greatandhra_dev_password@localhost:5432/greatandhra_cms?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_PREAUTH_SECRET=change-me-preauth-secret

ADMIN_ORIGIN=http://localhost:3000

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=greatandhra-media
S3_ACCESS_KEY=greatandhra
S3_SECRET_KEY=greatandhra_dev_password
# Public URL prefix the browser will load images from. With MinIO's default
# path-style routing and a public-read bucket policy, this is:
S3_PUBLIC_URL_BASE=http://localhost:9000/greatandhra-media

SEED_ADMIN_EMAIL=admin@greatandhra.com
